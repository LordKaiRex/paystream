# PayStream — Environment Configuration
# Copy to .env and fill in your actual values
# NEVER commit .env to git — use .gitignore to protect it

# ══════════════════════════════════════════════════════════════════
# SOLANA RPC — QuickNode (Recommended for production)
# ══════════════════════════════════════════════════════════════════
# Get from: https://dashboard.quicknode.com
# 1. Sign up and create a Solana Mainnet endpoint
# 2. Copy the HTTP and WSS URLs

QUICKNODE_RPC_URL=https://your-endpoint.solana-mainnet.quiknode.pro/YOUR_KEY/
QUICKNODE_WS_URL=wss://your-endpoint.solana-mainnet.quiknode.pro/YOUR_KEY/
QUICKNODE_API_KEY=your_quicknode_api_key
QUICKNODE_STREAMS_URL=https://api.quicknode.com/streams/rest/v1

# ══════════════════════════════════════════════════════════════════
# BIRDEYE — Live Token Prices
# ══════════════════════════════════════════════════════════════════
# Get from: https://docs.birdeye.so
# Free tier works for development/testing

BIRDEYE_API_KEY=your_birdeye_api_key

# ══════════════════════════════════════════════════════════════════
# SOLANA NETWORK
# ══════════════════════════════════════════════════════════════════
# Use 'mainnet-beta' for production submissions
# Use 'devnet' for testing (funds available via airdrop)

NETWORK=mainnet-beta

# ══════════════════════════════════════════════════════════════════
# SERVER KEYPAIR — For on-chain transaction signing
# ══════════════════════════════════════════════════════════════════
# IMPORTANT: This keypair MUST be generated securely and funded with ~0.05 SOL
# Generate once and store safely (consider using a hardware wallet / multisig in production)
#
# To generate:
#   node -e "import('./execute.js').then(m => m.generateServerKeypair())"
# 
# The output will show the address and secret key
# Fund the address with ~0.05 SOL (just enough for transaction fees)
# 
# SECURITY WARNING: In production, use a multi-sig wallet or hardware wallet
# instead of storing a plaintext keypair in .env

SERVER_KEYPAIR=[12,34,56,...]

# ══════════════════════════════════════════════════════════════════
# WEBHOOK SECURITY
# ══════════════════════════════════════════════════════════════════
# Random string used to validate QuickNode Stream webhooks
# Must match the header value configured in your QuickNode Stream
# Keep this secret!

WEBHOOK_SECRET=change_this_to_a_random_string_min_32_chars

# ══════════════════════════════════════════════════════════════════
# DEPLOYMENT URLS
# ══════════════════════════════════════════════════════════════════
# Set after deploying to production (Railway, Render, Fly.io, etc.)
# Used for webhooks and CORS configuration

WEBHOOK_URL=https://your-paystream-backend.railway.app
FRONTEND_URL=https://your-paystream.vercel.app
SERVER_PORT=3000

# ══════════════════════════════════════════════════════════════════
# ADMIN CREDENTIALS
# ══════════════════════════════════════════════════════════════════
# Used to manually trigger payroll runs (demo/testing only)
# Protect this value in production

ADMIN_SECRET=change_this_to_a_secure_admin_password

# ══════════════════════════════════════════════════════════════════
# LOGGING & DEBUG
# ══════════════════════════════════════════════════════════════════
# Set to 'true' for verbose logging during development

DEBUG=false

# ══════════════════════════════════════════════════════════════════
# DATABASE (Optional — for production)
# ══════════════════════════════════════════════════════════════════
# Currently using in-memory mock database
# For production, use Supabase PostgreSQL or similar
#
# DATABASE_URL=postgresql://user:password@host/paystream
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your_supabase_anon_key
# For manual payroll trigger endpoint
ADMIN_SECRET=another_random_secret

# ── Alerts (optional) ─────────────────────────────────────────────
# Slack webhook for payment failure alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

PORT=3001


# ── DEVNET TEST (.env.test) ───────────────────────────────────────
# For running test-devnet.js — copy these to .env.test

# Devnet QuickNode endpoint (or use public devnet)
QUICKNODE_DEVNET_RPC=https://api.devnet.solana.com

# Your test wallet private key (Uint8Array as JSON)
# Generate: solana-keygen new → export private key
TEST_WALLET_PRIVATE_KEY=[...]

# A second wallet to test sending to
TEST_CONTRACTOR_WALLET=SomeOtherWalletAddressHere
